# Samba AD Domain Configuration
# Copy this file to .env and customize the values
# .env is git-ignored and should never be committed

# Active Directory Domain Settings
DOMAIN=NRSH13-HADOOP
REALM=NRSH13-HADOOP.COM
DNS_DOMAIN=nrsh13-hadoop.com

# Administrator password (change this!)
ADMIN_PASS=Dummy@2929

# User Accounts
USER_NAME=768019
USER_PASS=Dummy@2929
USER2_NAME=768020
USER2_PASS=Dummy@2929

# Active Directory Groups
GROUP_NAME=A_HADOOP_ADMINS
SECOND_GROUP_NAME=A_Kafka_Users_Dev

# Docker Settings
CONTAINER_NAME=samba-ad-dc
IMAGE_NAME=local-samba-ad-dc

# TLS Certificate Configuration (optional)
# CERT_DIR=/path/to/certificates
# CERT_BASENAME=kafka-lab01.nrsh13-hadoop.com
# ROOT_CA_CERT=root-ca.crt
